# =====================================================================
# in.lj_test  —  Phase 1 toolchain validation ONLY
# =====================================================================
# Purpose:
#   Confirm that LAMMPS runs, writes a log, and writes a trajectory that
#   OVITO can open. This is a GENERIC Lennard-Jones fluid in reduced
#   (dimensionless) units. It contains NO real materials and NO real
#   force-field parameters — every value below is a standard LJ unit-test
#   value, not a fitted physical parameter for Si, C, or Li.
#
#   Do NOT use this file for any scientific result. It exists purely to
#   prove the environment works.
#
# Run with:
#   lmp -in in.lj_test
# (your LAMMPS binary may be named lmp_serial, lmp_mpi, or lammps)
# =====================================================================

# ---- 1. Units and atom style -----------------------------------------
# 'lj' = dimensionless Lennard-Jones units. Nothing here is in real eV/Å.
units           lj
atom_style      atomic

# ---- 2. Simulation box and atoms -------------------------------------
# Create a simple cubic lattice and fill a small periodic box with atoms.
# 'lattice fcc 0.8442' sets the reduced number density (a classic LJ value).
boundary        p p p
lattice         fcc 0.8442
region          simbox block 0 10 0 10 0 10
create_box      1 simbox
create_atoms    1 box

# ---- 3. Masses and interactions --------------------------------------
# Reduced units: mass = 1, epsilon = 1, sigma = 1, cutoff = 2.5 sigma.
# These are the textbook LJ test values, NOT physical constants.
mass            1 1.0
pair_style      lj/cut 2.5
pair_coeff      1 1 1.0 1.0 2.5

# ---- 4. Initial velocities -------------------------------------------
# Assign velocities from a fixed seed so the run is reproducible.
velocity        all create 1.44 87287 loop geom

# ---- 5. Neighbor list ------------------------------------------------
neighbor        0.3 bin
neigh_modify    every 20 delay 0 check no

# ---- 6. Integrator ---------------------------------------------------
# NVE: constant number, volume, energy — the simplest MD ensemble.
fix             1 all nve

# ---- 7. Thermodynamic output -----------------------------------------
# Print step, temperature, potential/kinetic/total energy, and pressure
# every 50 steps. This populates log.lammps so the analysis script has
# something to plot.
thermo          50
thermo_style    custom step temp pe ke etotal press

# ---- 8. Trajectory dump ----------------------------------------------
# Write atom positions every 50 steps to a .lammpstrj file that OVITO
# can open directly. This is the trajectory used for the OVITO screenshot.
dump            traj all atom 50 dump.lammpstrj

# ---- 9. Run ----------------------------------------------------------
# A short run is enough to prove the toolchain works.
run             500

# After this finishes you should have:
#   - log.lammps                  (thermo table -> plot_lammps_log.py)
#   - dump.lammpstrj              (trajectory  -> OVITO)
print "Phase 1 LJ test complete. Check log.lammps and dump.lammpstrj."
