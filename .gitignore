# ---- OS / editor cruft ----
.DS_Store
# MS Office temporary lock files (e.g. ~$methodology_paper.docx)
~$*

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# ---- Generated MD outputs (regenerate by running the LJ test) ----
# These are produced by LAMMPS; they are not source and can be large.
log.lammps
log.*.lammps
*.lammpstrj
*.dump
dump.*
restart.*

# Keep the directory structure but ignore its generated contents.
trajectories/*
!trajectories/.gitkeep

# ---- Generated structure files (regenerate via structures/build_graphene_li.py) ----
structures/graphene_li.xyz
structures/graphene_li.data

# ---- Phase 3 ReaxFF smoke-test outputs: KEPT as validation evidence ----
# These depend on the researcher-supplied ReaxFF file (not regenerable by
# others), so they are committed rather than ignored. Re-include them even
# though the generic *.lammpstrj / trajectories/* rules above would hide them.
!logs/reaxff_smoke_test.log
!trajectories/reaxff_smoke_test.lammpstrj

# ---- Phase 4 Model A outputs: KEPT as validation evidence ----
!trajectories/model_a_minimize.lammpstrj
!trajectories/model_a_equilibrate_short.lammpstrj

# ---- Phase 5 Model B outputs: KEPT as validation evidence ----
!trajectories/model_b_minimize.lammpstrj
!trajectories/model_b_equilibrate_short.lammpstrj

# ---- Generated figures (uncomment to ignore; kept by default as validation artifacts) ----
# figures/*.png
