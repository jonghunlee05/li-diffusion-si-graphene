thermo          25
thermo_style    custom step temp pe etotal press
dump            traj all atom 25 trajectories/model_a_equilibrate_short.lammpstrj

# Initial velocities for the mobile atoms only (bottom stays put).
velocity        mobile create ${TEQ} 48291 mom yes rot yes dist gaussian
velocity        mobile create 300 48291 mom yes rot yes dist gaussian

# Short NVT on the mobile atoms. Timestep 0.25 fs (Phase 3 conservative choice;
# Olou'ou Guifo et al. [4] used 0.5 and 0.1 fs).
fix             nvt mobile nvt temp ${TEQ} ${TEQ} 25.0
fix             nvt mobile nvt temp 300 ${TEQ} 25.0
fix             nvt mobile nvt temp 300 300 25.0
timestep        0.25
run             500          # 125 fs -- short stability check only

